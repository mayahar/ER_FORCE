<?xml version="1.0"?>
<PropertyList>
  <description>CorrActions aim marker — large billboard + strong distance scaling for long-range visibility</description>
  <author>ER_FORCE / CorrActions</author>
  <path>Models/aim_dot.ac</path>
  <texture-path></texture-path>
  <animation>
    <type>noshadow</type>
    <object-name>aim_dot</object-name>
  </animation>
  <animation>
    <type>billboard</type>
    <object-name>aim_dot</object-name>
    <spherical type="bool">true</spherical>
  </animation>
  <animation>
    <type>material</type>
    <object-name>aim_dot</object-name>
    <emission>
      <red>0.5</red>
      <green>1.0</green>
      <blue>0.55</blue>
      <factor>1.15</factor>
    </emission>
  </animation>
  <animation>
    <type>dist-scale</type>
    <object-name>aim_dot</object-name>
    <center>
      <x-m>0</x-m>
      <y-m>0</y-m>
      <z-m>0</z-m>
    </center>
    <interpolation>
      <entry>
        <ind>0</ind>
        <dep>1.65</dep>
      </entry>
      <entry>
        <ind>400</ind>
        <dep>1.65</dep>
      </entry>
      <entry>
        <ind>2000</ind>
        <dep>4.1</dep>
      </entry>
      <entry>
        <ind>8000</ind>
        <dep>8.2</dep>
      </entry>
      <entry>
        <ind>20000</ind>
        <dep>12.5</dep>
      </entry>
      <entry>
        <ind>40000</ind>
        <dep>17.5</dep>
      </entry>
    </interpolation>
  </animation>
</PropertyList>
